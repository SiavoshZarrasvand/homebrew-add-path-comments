#!/usr/bin/env ruby
# add-path-comments — add file path comments to TypeScript/TSX, Rust, and Python projects

VERSION = "1.0.1"

require 'yaml'

# ── Global excludes (apply to all project types) ─────────────────────────────
GLOBAL_EXCLUDE_DIRS = [
  "prisma",
  "public",
  "node_modules",
  "target",
  "dist",
  "build"
]

GLOBAL_EXCLUDE_PATH_SEGMENTS = [
  "/components/ui/"
]

# ── Config per project type ──────────────────────────────────────────────────
CONFIGS = {
  "ts" => {
    "extensions" => ["*.ts", "*.tsx", "*.js", "*.jsx", "*.mjs", "*.cjs"],
    "comment" => "//",
    "exclude_files" => [
      "next-env.d.ts", "tsconfig.json", "tsconfig.tsbuildinfo",
      "tailwind.config.ts", "vitest.config.ts", "postcss.config.mjs",
      "eslint.config.mjs", "components.json", "next.config.ts",
      "tailwind.config.js", "postcss.config.js", "next.config.js",
      "eslint.config.js", "eslint.config.cjs", "webpack.config.js"
    ]
  },
  "rust" => {
    "extensions" => ["*.rs"],
    "comment" => "//",
    "exclude_files" => []
  },
  "python" => {
    "extensions" => ["*.py"],
    "comment" => "#",
    "exclude_files" => ["__init__.py"]
  }
}

MARKERS = {
  "ts" => ["package.json"],
  "rust" => ["Cargo.toml"],
  "python" => ["pyproject.toml", "uv.lock"]
}

# ── Command line flags ────────────────────────────────────────────────────────
DRY_RUN = ARGV.include?("-d") || ARGV.include?("--dry-run")
HELP = ARGV.include?("-h") || ARGV.include?("--help")
VERSION_FLAG = ARGV.include?("-v") || ARGV.include?("--version")

def usage
  puts ""
  puts "add-path-comments v#{VERSION} — add file path comments to projects"
  puts ""
  puts "Usage:"
  puts "  add-path-comments [options] [path]"
  puts ""
  puts "Options:"
  puts "  -d, --dry-run    Show what would be added without modifying files"
  puts "  -v, --version    Print version"
  puts "  -h, --help       Show this help message"
  puts ""
end

if HELP
  usage
  exit 0
elsif VERSION_FLAG
  puts "add-path-comments v#{VERSION}"
  exit 0
end

# Filter out options to find target path
args = ARGV.reject { |arg| arg.start_with?("-") }
repo_root_path = args.empty? ? Dir.pwd : args[0]
repo_root = File.expand_path(repo_root_path)

if !Dir.exist?(repo_root)
  puts "Error: Directory does not exist: #{repo_root_path}"
  exit 1
end

# ── Load local configuration (.pcrc) ──────────────────────────────────────────
local_config = {}
[".pcrc", ".pcrc.yaml", ".pcrc.yml"].each do |filename|
  config_file = File.join(repo_root, filename)
  if File.exist?(config_file)
    begin
      local_config = YAML.safe_load(File.read(config_file)) || {}
      break
    rescue => e
      puts "Warning: Failed to parse configuration file #{filename}: #{e.message}"
    end
  end
end

custom_exclude_dirs = [local_config["exclude_dirs"]].flatten.compact
custom_exclude_files = [local_config["exclude_files"]].flatten.compact
custom_exclude_path_segments = [local_config["exclude_path_segments"]].flatten.compact
custom_projects = [local_config["projects"]].flatten.compact

# Merge exclusions
GLOBAL_EXCLUDE_DIRS.concat(custom_exclude_dirs).uniq!
GLOBAL_EXCLUDE_PATH_SEGMENTS.concat(custom_exclude_path_segments).uniq!

# ── Project discovery ─────────────────────────────────────────────────────────
def find_projects(root, custom_projects)
  projects = []

  # Add custom projects explicitly declared in .pcrc
  custom_projects.each do |proj_rel_path|
    proj_abs_path = File.expand_path(File.join(root, proj_rel_path))
    if Dir.exist?(proj_abs_path)
      MARKERS.each do |ptype, markers|
        if markers.any? { |m| File.exist?(File.join(proj_abs_path, m)) }
          projects << [proj_abs_path, ptype]
          break
        end
      end
    end
  end

  # Helper for recursive search up to depth 3
  search_dir = lambda do |dir, depth|
    return if depth > 3

    name = File.basename(dir)
    return if name.start_with?(".")
    return if GLOBAL_EXCLUDE_DIRS.include?(name)

    MARKERS.each do |ptype, markers|
      if markers.any? { |m| File.exist?(File.join(dir, m)) }
        unless projects.any? { |p_root, _| p_root == dir }
          projects << [dir, ptype]
        end
        break
      end
    end

    Dir.glob(File.join(dir, "*")).sort.each do |subdir|
      if File.directory?(subdir)
        search_dir.call(subdir, depth + 1)
      end
    end
  end

  # Check root itself
  MARKERS.each do |ptype, markers|
    if markers.any? { |m| File.exist?(File.join(root, m)) }
      unless projects.any? { |p_root, _| p_root == root }
        projects << [root, ptype]
      end
    end
  end

  # Scan subdirectories recursively (starting depth 2)
  Dir.glob(File.join(root, "*")).sort.each do |subdir|
    if File.directory?(subdir)
      search_dir.call(subdir, 2)
    end
  end

  projects
end

# ── Core logic ────────────────────────────────────────────────────────────────
def should_process?(file_path, config, repo_root, custom_exclude_files)
  file_str = file_path
  filename = File.basename(file_path)

  # Language-specific exclude files
  return false if config["exclude_files"].include?(filename)

  # Custom exclude files from .pcrc
  return false if custom_exclude_files.include?(filename)

  # Automatic dot-folder exclusion
  prefix = repo_root.end_with?("/") ? repo_root : "#{repo_root}/"
  if file_path.start_with?(prefix)
    relative_to_root = file_path.sub(/^#{Regexp.escape(prefix)}/, "")
    components = relative_to_root.split("/")
    dir_components = components[0..-2] || []
    if dir_components.any? { |c| c.start_with?(".") }
      return false
    end
  end

  # Global directory exclusions
  GLOBAL_EXCLUDE_DIRS.each do |d|
    return false if file_str.include?("/#{d}/")
  end

  # Global segment exclusions
  GLOBAL_EXCLUDE_PATH_SEGMENTS.each do |seg|
    return false if file_str.include?(seg)
  end

  true
end

def expected_comment(file_path, repo_root, comment_char)
  repo_root_parent = File.dirname(repo_root)
  prefix = repo_root_parent.end_with?("/") ? repo_root_parent : "#{repo_root_parent}/"
  relative = file_path.sub(/^#{Regexp.escape(prefix)}/, "")
  "#{comment_char} #{relative}"
end

def process_file(file_path, repo_root, comment_char, custom_exclude_files)
  content = File.read(file_path, encoding: "utf-8") rescue nil
  return unless content

  lines = content.split("\n", -1)
  expected = expected_comment(file_path, repo_root, comment_char)
  repo_root_parent = File.dirname(repo_root)
  parent_name = File.basename(repo_root_parent)

  # Already correct on line 1
  if lines.any? && lines[0].strip == expected
    return
  end

  # Exists somewhere other than line 1
  lines[1..-1]&.each do |line|
    stripped = line.strip
    if stripped == expected || stripped.start_with?("#{comment_char} #{parent_name}/")
      relative = file_path.sub(/^#{Regexp.escape(repo_root_parent + "/")}/, "")
      puts "[NOT TOP LINE] #{relative}"
      return
    end
  end

  relative = file_path.sub(/^#{Regexp.escape(repo_root_parent + "/")}/, "")

  if DRY_RUN
    puts "[dry-run] Would add top-line comment to #{relative}"
    return
  end

  # Preserve shebangs
  if lines.any? && lines[0].start_with?("#!")
    rest = lines[1..-1] ? lines[1..-1].join("\n") : ""
    new_content = lines[0] + "\n" + expected + "\n" + rest
  else
    new_content = expected + "\n" + content
  end

  File.write(file_path, new_content, encoding: "utf-8")
  puts "[ADDED] #{relative}"
end

# ── Run ───────────────────────────────────────────────────────────────────────
projects = find_projects(repo_root, custom_projects)

if projects.empty?
  puts "No recognisable projects found under #{repo_root}"
  exit 1
end

projects.each do |project_root, ptype|
  config = CONFIGS[ptype]
  repo_root_parent = File.dirname(repo_root)
  rel = project_root.sub(/^#{Regexp.escape(repo_root_parent + "/")}/, "")
  puts "\n── #{rel} ({ptype}) ──".gsub("{ptype}", ptype)

  files = []
  config["extensions"].each do |ext|
    glob_pattern = File.join(project_root, "**", ext)
    files.concat(Dir.glob(glob_pattern, File::FNM_DOTMATCH))
  end

  # Sort files and filter for files only
  files.uniq.sort.each do |file_path|
    next unless File.file?(file_path)
    if should_process?(file_path, config, repo_root, custom_exclude_files)
      process_file(file_path, repo_root, config["comment"], custom_exclude_files)
    end
  end
end
